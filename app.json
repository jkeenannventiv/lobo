{
  "expo": {
    "name": "Lobo",
    "slug": "lobo",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0d1b2a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.getlobo.lobo",
      "buildNumber": "9",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Lobo uses your location to detect      your home and work areas so it can accurately label visits in your movement history — for example, marking time spent at your home address as 'Home'.",
        "NSUserTrackingUsageDescription": "Lobo uses this to share anonymous behavioral segment flags (such as 'frequent restaurant visitor') to help improve the app. Your identity and location history are never shared."
       }
    },
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.getlobo.lobo",
      "versionCode": 7,
      "googleServicesFile": "./google-services.json",
      "navigationBar": {
        "backgroundColor": "#ffffff",
        "barStyle": "dark-content"
      },
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-tracking-transparency",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": ["RNFBApp", "RNFBAuth"]
           }
        }
      ],
      "./plugins/withRemoveAdId"     
     ],
    "extra": {
      "eas": {
        "projectId": "b2900671-907f-481f-b211-4a3cb987c701"
      }
    }
  }
}
